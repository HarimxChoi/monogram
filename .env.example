# Monogram — environment variables
# Copy to .env and fill in values

# Telegram — personal account (get from my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Telegram — bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram numeric user ID (get from @userinfobot)
TELEGRAM_USER_ID=

# GitHub fine-grained PAT with Contents: Read and write on the repo below
GITHUB_PAT=
GITHUB_REPO=HarimxChoi/mono

# LLM credentials — fill ONLY the one you use (choose at `monogram init`)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: comma-separated repos for the daily commit digest
# MONOGRAM_WATCH_REPOS=HarimxChoi/paper-a,HarimxChoi/project-b

# LLM model configuration lives in mono/config.md (vault-level), not .env.
# Run `monogram init` to set it up, or edit mono/config.md directly.
#
# Legacy compatibility (v0.3 users upgrading): if mono/config.md has no
# llm_provider, Monogram falls back to this env var and logs a warning.
# New setups should leave this empty.
# MONOGRAM_MODEL=
