<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Monogram</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@300;400;500;600&family=IBM+Plex+Serif:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; background: #070910; color: #E6EDF3; font-family: 'IBM Plex Sans', -apple-system, sans-serif; }
body { display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 24px; }
#prompt { width: 100%; max-width: 360px; text-align: center; }
#prompt h1 { font-family: 'IBM Plex Mono', ui-monospace, monospace; letter-spacing: 0.22em; font-size: 16px; font-weight: 600; color: #E6EDF3; margin-bottom: 28px; }
#prompt h1::before { content: '◈ '; color: #00D4A8; }
#pw { width: 100%; padding: 12px 14px; background: #141821; border: 1px solid #232833; color: #E6EDF3; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 14px; border-radius: 2px; outline: none; letter-spacing: 0.02em; }
#pw:focus { border-color: #00D4A8; box-shadow: 0 0 0 1px rgba(0, 212, 168, 0.25); }
#unlock { margin-top: 12px; width: 100%; padding: 10px 14px; background: #00D4A8; border: none; color: #070910; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 13px; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; border-radius: 2px; cursor: pointer; transition: opacity 120ms ease; }
#unlock:hover { opacity: 0.9; }
#unlock[disabled] { opacity: 0.5; cursor: progress; }
#error { margin-top: 16px; color: #F14C5E; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; }
#content { min-height: 100vh; }
#spinner { display: none; margin-top: 12px; color: #8B949E; font-family: 'IBM Plex Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; }
</style>
</head>
<body>
<div id="prompt">
  <h1>MONOGRAM</h1>
  <input type="password" id="pw" autofocus autocomplete="off" placeholder="password">
  <button id="unlock">Unlock</button>
  <div id="error" hidden>Incorrect password</div>
  <div id="spinner">Deriving key…</div>
</div>
<div id="content" hidden></div>
<script>
const ENCRYPTED = "__ENCRYPTED_BLOB__";
const PBKDF2_ITERATIONS = 600000;
async function decrypt(password, encryptedB64) {
  const raw = Uint8Array.from(atob(encryptedB64), c => c.charCodeAt(0));
  const salt = raw.slice(0, 16);
  const nonce = raw.slice(16, 28);
  const ciphertextAndTag = raw.slice(28);
  const passwordBytes = new TextEncoder().encode(password);
  const baseKey = await crypto.subtle.importKey(
    'raw', passwordBytes, 'PBKDF2', false, ['deriveKey']
  );
  const key = await crypto.subtle.deriveKey(
    { name: 'PBKDF2', salt, iterations: PBKDF2_ITERATIONS, hash: 'SHA-256' },
    baseKey,
    { name: 'AES-GCM', length: 256 },
    false, ['decrypt']
  );
  const plaintext = await crypto.subtle.decrypt(
    { name: 'AES-GCM', iv: nonce }, key, ciphertextAndTag
  );
  return new TextDecoder().decode(plaintext);
}
async function unlock() {
  const pwEl = document.getElementById('pw');
  const errEl = document.getElementById('error');
  const spinEl = document.getElementById('spinner');
  const btn = document.getElementById('unlock');
  errEl.hidden = true;
  spinEl.style.display = 'block';
  btn.disabled = true;
  try {
    const html = await decrypt(pwEl.value, ENCRYPTED);
    const contentEl = document.getElementById('content');
    contentEl.innerHTML = html;
    document.getElementById('prompt').hidden = true;
    contentEl.hidden = false;
    // Re-run any <script> elements in the decrypted HTML
    contentEl.querySelectorAll('script').forEach(old => {
      const s = document.createElement('script');
      for (const a of old.attributes) s.setAttribute(a.name, a.value);
      s.textContent = old.textContent;
      old.parentNode.replaceChild(s, old);
    });
  } catch (e) {
    errEl.hidden = false;
    pwEl.value = '';
    pwEl.focus();
  } finally {
    spinEl.style.display = 'none';
    btn.disabled = false;
  }
}
document.getElementById('unlock').addEventListener('click', unlock);
document.getElementById('pw').addEventListener('keydown', e => {
  if (e.key === 'Enter') unlock();
});
</script>
</body>
</html>
